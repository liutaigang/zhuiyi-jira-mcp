{
  "name": "zhuiyi-jira-mcp",
  "version": "0.1.0",
  "description": "Read-only Jira requirement MCP server for fetching structured requirement context by Jira URL.",
  "type": "module",
  "bin": {
    "zhuiyi-jira-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "check:jira": "tsx scripts/check-jira.ts",
    "check:jira:curl": "bash scripts/check-jira-curl.sh",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
